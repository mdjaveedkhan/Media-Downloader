div&gt;&#10;            &lt;/div&gt;&#10;            &lt;div class=&quot;progress-stats&quot;&gt;&#10;                &lt;span id=&quot;percentText&quot;&gt;0%&lt;/span&gt;&#10;                &lt;span id=&quot;sizeText&quot;&gt;0 MB / 0 MB&lt;/span&gt;&#10;                &lt;span id=&quot;speedText&quot;&gt;0 MB/s&lt;/span&gt;&#10;                &lt;span id=&quot;etaText&quot;&gt;ETA: -&lt;/span&gt;&#10;            &lt;/div&gt;&#10;        &lt;/section&gt;&#10;&#10;        &lt;p id=&quot;message&quot; class=&quot;message&quot;&gt;&lt;/p&gt;&#10;&#10;        &lt;div class=&quot;note&quot;&gt;&#10;            &lt;p&gt;&lt;strong&gt;Note:&lt;/strong&gt; Browser saves downloaded files to your system download folder based on browser settings.&lt;/p&gt;&#10;            &lt;p&gt;Private or age-restricted content may need your cookies. Add cookies at page visit or in the field above.&lt;/p&gt;&#10;        &lt;/div&gt;&#10;&#10;        &lt;footer class=&quot;site-footer&quot;&gt;&#10;            &lt;span&gt;Built for personal use.&lt;/span&gt;&#10;            &lt;span&gt;Respect creator rights and platform rules.&lt;/span&gt;&#10;        &lt;/footer&gt;&#10;    &lt;/main&gt;&#10;&lt;/div&gt;&#10;&#10;&lt;script&gt;&#10;    const urlInput = document.getElementById('url');&#10;    const fetchBtn = document.getElementById('fetchBtn');&#10;    const downloadBtn = document.getElementById('downloadBtn');&#10;    const cookiesText = document.getElementById('cookiesText');&#10;    const messageEl = document.getElementById('message');&#10;&#10;    const metaSection = document.getElementById('metaSection');&#10;    const controlsSection = document.getElementById('controlsSection');&#10;    const progressSection = document.getElementById('progressSection');&#10;&#10;    const thumbnail = document.getElementById('thumbnail');&#10;    const titleText = document.getElementById('titleText');&#10;    const platformText = document.getElementById('platformText');&#10;    const durationText = document.getElementById('durationText');&#10;    const uploaderText = document.getElementById('uploaderText');&#10;&#10;    const mediaType = document.getElementById('mediaType');&#10;    const videoQualityWrap = document.getElementById('videoQualityWrap');&#10;    const audioQualityWrap = document.getElementById('audioQualityWrap');&#10;    const videoQuality = document.getElementById('videoQuality');&#10;    const audioQuality = document.getElementById('audioQuality');&#10;&#10;    const statusText = document.getElementById('statusText');&#10;    const elapsedText = document.getElementById('elapsedText');&#10;    const progressBar = document.getElementById('progressBar');&#10;    const percentText = document.getElementById('percentText');&#10;    const sizeText = document.getElementById('sizeText');&#10;    const speedText = document.getElementById('speedText');&#10;    const etaText = document.getElementById('etaText');&#10;&#10;    let currentJobId = null;&#10;    let progressTimer = null;&#10;    let retryingWithCookies = false;&#10;&#10;    function setMessage(text, isError = false) {&#10;        messageEl.textContent = text;&#10;        messageEl.classList.toggle('error', isError);&#10;    }&#10;&#10;    function toggleTypeControls() {&#10;        const isMp3 = mediaType.value === 'mp3';&#10;        videoQualityWrap.classList.toggle('hidden', isMp3);&#10;        audioQualityWrap.classList.toggle('hidden', !isMp3);&#10;    }&#10;&#10;    function resetProgressUI() {&#10;        progressBar.style.width = '0%';&#10;        percentText.textContent = '0%';&#10;        sizeText.textContent = '0 MB / 0 MB';&#10;        speedText.textContent = '0 MB/s';&#10;        etaText.textContent = 'ETA: -';&#10;        elapsedText.textContent = '00:00';&#10;        statusText.textContent = 'Idle';&#10;    }&#10;&#10;    function getCookiesText() {&#10;        const value = cookiesText.value.trim();&#10;        localStorage.setItem('avd_cookies_text', value);&#10;        return value;&#10;    }&#10;&#10;    function askCookiesOnVisit() {&#10;        const saved = localStorage.getItem('avd_cookies_text') || '';&#10;        if (saved) {&#10;            cookiesText.value = saved;&#10;            return;&#10;        }&#10;&#10;        const shouldAdd = window.confirm('Do you want to add cookies for private or age-restricted downloads?');&#10;        if (!shouldAdd) {&#10;            return;&#10;        }&#10;&#10;        const pasted = window.prompt('Paste your cookies.txt content (optional). You can leave empty and add it later.');&#10;        if (pasted &amp;&amp; pasted.trim()) {&#10;            cookiesText.value = pasted.trim();&#10;            localStorage.setItem('avd_cookies_text', cookiesText.value);&#10;        }&#10;    }&#10;&#10;    function askForCookiesNow() {&#10;        const pasted = window.prompt('This URL needs login cookies. Paste your cookies.txt content to continue:');&#10;        if (!pasted || !pasted.trim()) {&#10;            return false;&#10;        }&#10;        cookiesText.value = pasted.trim();&#10;        localStorage.setItem('avd_cookies_text', cookiesText.value);&#10;        return true;&#10;    }&#10;&#10;    function triggerAutoDownload(downloadUrl) {&#10;        if (!downloadUrl) return;&#10;        const anchor = document.createElement('a');&#10;        anchor.href = downloadUrl;&#10;        anchor.style.display = 'none';&#10;        document.body.appendChild(anchor);&#10;        anchor.click();&#10;        document.body.removeChild(anchor);&#10;    }&#10;&#10;    async function fetchInfo() {&#10;        const url = urlInput.value.trim();&#10;        if (!url) {&#10;            setMessage('Please paste a URL first.', true);&#10;            return;&#10;        }&#10;&#10;        setMessage('Fetching media info...');&#10;        downloadBtn.disabled = true;&#10;        fetchBtn.disabled = true;&#10;&#10;        try {&#10;            const response = await fetch('/api/info', {&#10;                method: 'POST',&#10;                headers: { 'Content-Type': 'application/json' },&#10;                body: JSON.stringify({&#10;                    url,&#10;                    cookies_text: getCookiesText()&#10;                })&#10;            });&#10;&#10;            const data = await response.json();&#10;            if (!data.ok) {&#10;                if (data.needs_cookies &amp;&amp; !getCookiesText() &amp;&amp; !retryingWithCookies) {&#10;                    const accepted = window.confirm('This media requires login cookies. Add cookies now and retry?');&#10;                    if (accepted &amp;&amp; askForCookiesNow()) {&#10;                        retryingWithCookies = true;&#10;                        await fetchInfo();&#10;                        return;&#10;                    }&#10;                }&#10;                throw new Error(data.error || 'Could not fetch media info.');&#10;            }&#10;&#10;            const info = data.info;&#10;&#10;            titleText.textContent = info.title || '-';&#10;            platformText.textContent = info.platform || '-';&#10;            durationText.textContent = info.duration_text || '-';&#10;            uploaderText.textContent = info.uploader || '-';&#10;&#10;            if (info.thumbnail) {&#10;                thumbnail.src = info.thumbnail_proxy || info.thumbnail;&#10;                thumbnail.onerror = () =&gt; {&#10;                    thumbnail.classList.add('hidden');&#10;                };&#10;                thumbnail.classList.remove('hidden');&#10;            } else {&#10;                thumbnail.classList.add('hidden');&#10;            }&#10;&#10;            videoQuality.innerHTML = '';&#10;            const bestOption = document.createElement('option');&#10;            bestOption.value = 'best';&#10;            bestOption.textContent = 'Best available (default high quality)';&#10;            videoQuality.appendChild(bestOption);&#10;&#10;            (info.video_options || []).forEach((fmt) =&gt; {&#10;                const option = document.createElement('option');&#10;                option.value = fmt.value;&#10;                option.textContent = fmt.label;&#10;                videoQuality.appendChild(option);&#10;            });&#10;&#10;            metaSection.classList.remove('hidden');&#10;            controlsSection.classList.remove('hidden');&#10;            progressSection.classList.remove('hidden');&#10;&#10;            resetProgressUI();&#10;            toggleTypeControls();&#10;            downloadBtn.disabled = false;&#10;            setMessage('Info loaded. Choose options and start download.');&#10;        } catch (error) {&#10;            setMessage(error.message || 'Failed to fetch info.', true);&#10;        } finally {&#10;            retryingWithCookies = false;&#10;            fetchBtn.disabled = false;&#10;        }&#10;    }&#10;&#10;    async function startDownload() {&#10;        const url = urlInput.value.trim();&#10;        if (!url) {&#10;            setMessage('Please paste a URL first.', true);&#10;            return;&#10;        }&#10;&#10;        resetProgressUI();&#10;        statusText.textContent = 'Starting';&#10;        setMessage('Starting download...');&#10;        downloadBtn.disabled = true;&#10;&#10;        try {&#10;            const payload = {&#10;                url,&#10;                media_type: mediaType.value,&#10;                quality: videoQuality.value || 'best',&#10;                audio_quality: audioQuality.value || '320',&#10;                cookies_text: getCookiesText()&#10;            };&#10;&#10;            const response = await fetch('/api/download', {&#10;                method: 'POST',&#10;                headers: { 'Content-Type': 'application/json' },&#10;                body: JSON.stringify(payload)&#10;            });&#10;&#10;            const data = await response.json();&#10;            if (!data.ok) {&#10;                if (data.needs_cookies &amp;&amp; !getCookiesText()) {&#10;                    const accepted = window.confirm('Download requires login cookies. Add cookies now and retry?');&#10;                    if (accepted &amp;&amp; askForCookiesNow()) {&#10;                        await startDownload();&#10;                        return;&#10;                    }&#10;                }&#10;                throw new Error(data.error || 'Could not start download.');&#10;            }&#10;&#10;            currentJobId = data.job_id;&#10;            if (progressTimer) {&#10;                clearInterval(progressTimer);&#10;            }&#10;            progressTimer = setInterval(updateProgress, 1000);&#10;        } catch (error) {&#10;            setMessage(error.message || 'Failed to start download.', true);&#10;            statusText.textContent = 'Failed';&#10;            downloadBtn.disabled = false;&#10;        }&#10;    }&#10;&#10;    async function updateProgress() {&#10;        if (!currentJobId) return;&#10;&#10;        try {&#10;            const response = await fetch(`/api/progress/${currentJobId}`);&#10;            const data = await response.json();&#10;            if (!data.ok) {&#10;                throw new Error(data.error || 'Progress unavailable.');&#10;            }&#10;&#10;            const job = data.job;&#10;            const p = job.progress;&#10;&#10;            const percent = Number(p.percent || 0).toFixed(2);&#10;            progressBar.style.width = `${Math.min(100, Number(percent))}%`;&#10;            percentText.textContent = `${percent}%`;&#10;            sizeText.textContent = `${p.downloaded_text} / ${p.total_text}`;&#10;            speedText.textContent = p.speed_text;&#10;            etaText.textContent = `ETA: ${p.eta_text}`;&#10;            elapsedText.textContent = p.elapsed_text;&#10;            statusText.textContent = p.status_text;&#10;&#10;            if (job.status === 'completed') {&#10;                clearInterval(progressTimer);&#10;                progressTimer = null;&#10;                setMessage('Download completed. Starting file download...');&#10;                triggerAutoDownload(job.download_url);&#10;                downloadBtn.disabled = false;&#10;            } else if (job.status === 'failed') {&#10;                clearInterval(progressTimer);&#10;                progressTimer = null;&#10;                if (job.needs_cookies &amp;&amp; !getCookiesText()) {&#10;                    const accepted = window.confirm('This failed due to login/cookies. Add cookies now and retry download?');&#10;                    if (accepted &amp;&amp; askForCookiesNow()) {&#10;                        await startDownload();&#10;                        return;&#10;                    }&#10;                }&#10;                setMessage(job.error || 'Download failed.', true);&#10;                statusText.textContent = 'Failed';&#10;                downloadBtn.disabled = false;&#10;            }&#10;        } catch (error) {&#10;            clearInterval(progressTimer);&#10;            progressTimer = null;&#10;            setMessage(error.message || 'Could not update progress.', true);&#10;            downloadBtn.disabled = false;&#10;        }&#10;    }&#10;&#10;    fetchBtn.addEventListener('click', fetchInfo);&#10;    downloadBtn.addEventListener('click', startDownload);&#10;    mediaType.addEventListener('change', toggleTypeControls);&#10;    askCookiesOnVisit();&#10;&lt;/script&gt;&#10;&lt;/body&gt;&#10;&lt;/html&gt;&#10;&#10;" />
